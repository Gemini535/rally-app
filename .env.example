# Pooled PostgreSQL connection string used by the application.
DATABASE_URL=
# Direct PostgreSQL connection string used for Prisma migrations.
DIRECT_URL=
# Public URL of the Supabase project.
NEXT_PUBLIC_SUPABASE_URL=
# Public anonymous Supabase API key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Private Supabase service-role key for server-only operations.
SUPABASE_SERVICE_ROLE_KEY=
# JWT signing secret configured in Supabase.
SUPABASE_JWT_SECRET=
# Public Mapbox access token used by the web map.
NEXT_PUBLIC_MAPBOX_TOKEN=
# Public base URL for the standalone API during local development.
NEXT_PUBLIC_API_URL=http://localhost:4000
# Enables mock data in the web app when set to true.
NEXT_PUBLIC_USE_MOCKS=false
# Shared password used by seeded demo accounts.
DEMO_PASSWORD=
# Recommendation weight for a user's personal preference.
RECO_W_PERSONAL=0.35
# Recommendation weight for social affinity.
RECO_W_SOCIAL=0.25
# Recommendation weight for venue proximity.
RECO_W_PROXIMITY=0.20
# Recommendation weight for live venue activity.
RECO_W_LIVE=0.20
# Proximity decay distance in kilometres.
RECO_PROXIMITY_D0_KM=3.0
